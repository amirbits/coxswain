{
  "name": "helm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first command-and-control workspace for agentic software work.",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "server": "bun run server/index.ts",
